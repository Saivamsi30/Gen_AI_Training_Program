# 1. Define a reusable testing function
def run_filtered_query(user_query, target_category, n_results=2):
    print(f"❓ Question: '{user_query}'")
    print(f"🎯 Filter Applied: category = '{target_category}'")
    
    # Convert the question to a vector
    query_embedding = model.encode(user_query).tolist()
    
    # Search ChromaDB with the metadata filter
    results = collection.query(
        query_embeddings=[query_embedding],
        n_results=n_results,
        where={"category": target_category} # This is the crucial metadata filter
    )
    
    # Display the results
    if results['documents'] and results['documents'][0]:
        for i, doc in enumerate(results['documents'][0]):
            print(f"\n📄 Result {i + 1} (ID: {results['ids'][0][i]}):")
            print(f"{doc}")
    else:
        print("\n❌ No results found for this filter.")
    print("\n" + "="*50 + "\n")

